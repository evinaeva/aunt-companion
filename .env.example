# Telegram
TELEGRAM_BOT_TOKEN=0000000000:TEST_TOKEN_REPLACE_ME
ALLOWED_TELEGRAM_USER_IDS=123456789,987654321
ADMIN_TELEGRAM_USER_ID=123456789

# Runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Storage
SQLITE_PATH=./data/db/gosha.sqlite3

# LLM fallback (used when config/llm.local.toml is absent)
LLM_PROVIDER=gemini
LLM_BASE_URL=https://generativelanguage.googleapis.com
LLM_MODEL=gemini-2.5-flash-lite
LLM_API_KEY=YOUR_GEMINI_API_KEY

# STT
STT_PROVIDER=faster_whisper
STT_MODEL_SIZE=small
STT_COMPUTE_TYPE=int8

# TTS (Google Cloud via ADC)
TTS_PROVIDER=google_cloud
TTS_LANGUAGE_CODE=ru-RU
TTS_VOICE_NAME=ru-RU-Wavenet-C
TTS_VOICE_GENDER=FEMALE
TTS_AUDIO_ENCODING=OGG_OPUS
TTS_TIMEOUT_SECONDS=10.0
VOICE_ENABLED_DEFAULT=false

# Operator notes (ADC, no key files)
# GOOGLE_CLOUD_PROJECT=project-d245d8c8-8548-47d2-a04
# Authenticate with ADC + SA impersonation:
# gcloud auth application-default login \
#   --impersonate-service-account=gosha-tts-sa@project-d245d8c8-8548-47d2-a04.iam.gserviceaccount.com
# Do not use JSON key files.

# App paths
DATA_DIR=./data
TMP_DIR=./data/tmp
LOG_DIR=./data/logs
