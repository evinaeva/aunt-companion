# Telegram
TELEGRAM_BOT_TOKEN=0000000000:TEST_TOKEN_REPLACE_ME
ALLOWED_TELEGRAM_USER_IDS=123456789,987654321
ADMIN_TELEGRAM_USER_ID=123456789

# Runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Storage
SQLITE_PATH=./data/db/gosha.sqlite3

# LLM fallback (used when config/llm.local.toml is absent)
LLM_PROVIDER=gemini
LLM_BASE_URL=https://generativelanguage.googleapis.com
LLM_MODEL=gemini-2.5-flash-lite
LLM_API_KEY=YOUR_GEMINI_API_KEY

# STT
STT_MODEL_SIZE=small
STT_COMPUTE_TYPE=int8

# TTS
PIPER_VOICE_PATH=./data/models/tts/ru_RU-irina-medium.onnx

# App paths
DATA_DIR=./data
TMP_DIR=./data/tmp
LOG_DIR=./data/logs
