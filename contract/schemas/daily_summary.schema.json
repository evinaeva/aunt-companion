{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DailySummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "user_id",
    "summary_date",
    "summary_text",
    "updated_at"
  ],
  "properties": {
    "user_id": {
      "type": "integer",
      "minimum": 1
    },
    "summary_date": {
      "type": "string",
      "format": "date"
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "source_message_range_start": {
      "type": [
        "integer",
        "null"
      ]
    },
    "source_message_range_end": {
      "type": [
        "integer",
        "null"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
