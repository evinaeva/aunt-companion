{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserSettings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "user_id",
    "voice_enabled",
    "updated_at"
  ],
  "properties": {
    "user_id": {
      "type": "integer",
      "minimum": 1
    },
    "voice_enabled": {
      "type": "boolean"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
