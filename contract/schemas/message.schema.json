{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Message",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "user_id",
    "role",
    "input_type",
    "text",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "user_id": {
      "type": "integer",
      "minimum": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant",
        "system"
      ]
    },
    "input_type": {
      "type": "string",
      "enum": [
        "text",
        "voice",
        "command"
      ]
    },
    "text": {
      "type": "string"
    },
    "telegram_message_id": {
      "type": [
        "integer",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}