[Unit]
Description=Gosha Telegram bot
After=network.target gosha-llama.service
Requires=gosha-llama.service

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__PROJECT_ROOT__
EnvironmentFile=__PROJECT_ROOT__/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=__PROJECT_ROOT__/scripts/05_run_bot.sh __PROJECT_ROOT__
Restart=always
RestartSec=5
TimeoutStopSec=20
KillSignal=SIGINT

[Install]
WantedBy=multi-user.target
